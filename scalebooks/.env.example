# ── Database (Postgres / Supabase / Neon) ──────────────────────
# Use the pooled connection string for the app, direct for migrations.
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/scalebooks"
DATABASE_URL_DIRECT="postgresql://postgres:postgres@localhost:5432/scalebooks"

# ── API ────────────────────────────────────────────────────────
API_PORT=8787

# ── Auth (Supabase Auth or Firebase Auth — verify JWTs server-side) ──
# JWT issuer + JWKS endpoint the API uses to validate the caller's token.
AUTH_JWKS_URL=""
AUTH_ISSUER=""

# ── Web (Vite — only VITE_* is exposed to the browser) ─────────
VITE_API_BASE_URL="http://localhost:8787"
