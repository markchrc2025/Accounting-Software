# ── Database (PostgreSQL — Sliplane, self-hosted, or any Postgres 15+) ─────────
# The API connects as the RLS-bound sentire_books_app role; migrations + seed run
# as the owner/superuser. `sslmode=no-verify` is handled by the DB client (maps to
# encrypted, non-verifying TLS) — keep it for hosts that require TLS, drop it for a
# plain internal connection.
#
# API (as the RLS-bound app role):
DATABASE_URL="postgres://sentire_books_app:[APP_PASSWORD]@[DB_HOST]:[DB_PORT]/sentire_books?sslmode=no-verify"
# Migrations + seed (as the owner/superuser):
DATABASE_URL_DIRECT="postgres://owner:[DB_PASSWORD]@[DB_HOST]:[DB_PORT]/sentire_books?sslmode=no-verify"

# ── API ────────────────────────────────────────────────────────
API_PORT=8787

# ── Auth (Authenticize — OIDC Authorization Code flow) ─────────────────────────
# Sentire Books is a confidential OAuth client of Authenticize. The API runs the
# login redirect + code exchange (GET /auth/login, GET /api/auth/callback/authenticize)
# and verifies the resulting RS256 id_token against the JWKS + issuer. Register the
# app in Authenticize → Applications and copy the client id/secret here.
AUTH_ISSUER="https://auth.example.com"
AUTH_JWKS_URL="https://auth.example.com/api/auth/jwks"
AUTH_CLIENT_ID="your-oauth-client-id"
AUTH_CLIENT_SECRET="your-oauth-client-secret"
# Must match a Redirect URI registered in Authenticize, character-for-character.
AUTH_REDIRECT_URI="https://api.books.example.com/api/auth/callback/authenticize"
# Where the API sends the browser back after login (the web app's origin). Falls
# back to the first CORS_ORIGIN entry if unset.
WEB_APP_URL="https://books.example.com"
# Optional: secret used to sign the short-lived login state cookie. Defaults to
# AUTH_CLIENT_SECRET when unset.
# AUTH_STATE_SECRET="a-long-random-string"
# Allowed browser origins for the API (comma-separated).
CORS_ORIGIN="https://books.example.com,http://localhost:5173"
# Dev only: when AUTH_ISSUER/AUTH_JWKS_URL are unset, trust an x-user-id header so
# the API runs locally without an IdP. NEVER set this true in production.
AUTH_DEV_BYPASS="false"

# ── Web (Vite — only VITE_* is exposed to the browser) ─────────
# The API base URL doubles as the OIDC login entry point (login redirects to
# VITE_API_BASE_URL/auth/login). No auth secrets are exposed to the browser.
VITE_API_BASE_URL="http://localhost:8787"
# Dev only: sent as x-user-id when auth is NOT configured locally.
VITE_DEV_USER_ID="00000000-0000-0000-0000-0000000000b1"
