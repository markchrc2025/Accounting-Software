# ── Database (Supabase Postgres) ───────────────────────────────
# From Supabase → Database → Connect. The API uses the TRANSACTION POOLER (6543)
# as the scalebooks_app role; migrations + seed use the DIRECT connection (5432)
# as the postgres owner. Replace [PASSWORD] with the real role/db passwords.
#
# API (pooler, as the RLS-bound app role):
DATABASE_URL="postgresql://scalebooks_app.mqsdymealtdrzmbnvvoc:[APP_PASSWORD]@aws-1-ap-southeast-2.pooler.supabase.com:6543/postgres"
# Migrations + seed (direct, as owner):
DATABASE_URL_DIRECT="postgresql://postgres:[DB_PASSWORD]@db.mqsdymealtdrzmbnvvoc.supabase.co:5432/postgres"
# NOTE: this project is in ap-southeast-2 (Sydney). Copy the exact host from your
# Supabase Connect dialog if it ever differs.

# ── API ────────────────────────────────────────────────────────
API_PORT=8787

# ── Auth (Supabase Auth — verified server-side via JWKS) ───────
AUTH_JWKS_URL="https://mqsdymealtdrzmbnvvoc.supabase.co/auth/v1/.well-known/jwks.json"
AUTH_ISSUER="https://mqsdymealtdrzmbnvvoc.supabase.co/auth/v1"
# Dev only: when AUTH_JWKS_URL is unset, trust an x-user-id header so the API runs
# locally without an IdP. NEVER set this true in production.
AUTH_DEV_BYPASS="false"

# ── Web (Vite — only VITE_* is exposed to the browser) ─────────
VITE_API_BASE_URL="http://localhost:8787"
# Supabase project + PUBLISHABLE key (safe to expose; protected by RLS).
VITE_SUPABASE_URL="https://mqsdymealtdrzmbnvvoc.supabase.co"
VITE_SUPABASE_PUBLISHABLE_KEY="sb_publishable_roR2UnE41AKs4Qwb8fQuKQ_nHp8EgKD"
# Dev only: sent as x-user-id when Supabase auth is NOT configured locally.
VITE_DEV_USER_ID="00000000-0000-0000-0000-0000000000b1"
