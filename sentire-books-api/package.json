{
  "name": "sentire-books-api",
  "private": true,
  "version": "0.1.0",
  "description": "Sentire Books \u2014 Philippine cloud accounting. Clean monorepo foundation (Postgres + TypeScript).",
  "type": "module",
  "packageManager": "pnpm@9.12.0",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "lint": "turbo run lint",
    "typecheck": "turbo run typecheck",
    "test": "turbo run test",
    "db:generate": "pnpm --filter @sentire-books/db generate",
    "db:migrate": "pnpm --filter @sentire-books/db migrate"
  },
  "devDependencies": {
    "turbo": "^2.3.3",
    "typescript": "^5.6.3"
  }
}
